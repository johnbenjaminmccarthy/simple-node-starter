{
  "name": "simple-node-starter",
  "version": "1.0.0",
  "description": "A simple starter template for a Node.js project configured with PNPM, oxlint, oxfmt, and Vitest.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --build --clean && tsc --project tsconfig.build.json",
    "test:unit": "vitest run --passWithNoTests test/unit",
    "test:integration": "vitest run --passWithNoTests test/integration",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format && pnpm typecheck && pnpm test",
    "check:fix": "pnpm lint:fix && pnpm format:fix && pnpm typecheck && pnpm test",
    "prepublishOnly": "pnpm install --frozen-lockfile && pnpm check && pnpm build",
    "ci:add": "changeset add",
    "ci:version": "changeset version",
    "ci:publish": "changeset publish --tag && git push --follow-tags"
  },
  "keywords": [],
  "author": "Your Name Here",
  "license": "MIT",
  "sideEffects": false,
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.3.0",
    "changeset": "^0.2.6",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
